{
  "name": "gitter",
  "version": "1.0.0",
  "description": "Git repository registry - track, search, and navigate your local repos",
  "type": "module",
  "bin": {
    "gitter": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "git",
    "registry",
    "cli",
    "repository",
    "navigation"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
